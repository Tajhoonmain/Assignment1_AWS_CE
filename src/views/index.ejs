<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="University Event Management System - Browse and register for university events">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-calendar-alt me-2"></i>UniEvent
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/events">All Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/events/search">Search</a>
                    </li>
                </ul>
                
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="#" onclick="showUploadModal()">
                            <i class="fas fa-upload me-1"></i>Upload Poster
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section text-white text-center py-5">
        <div class="container">
            <h1 class="display-4 fw-bold mb-4">University Event Management System</h1>
            <p class="lead mb-4">Discover and register for exciting university events</p>
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="input-group">
                        <input type="text" class="form-control form-control-lg" id="searchInput" placeholder="Search events...">
                        <button class="btn btn-warning btn-lg" type="button" onclick="searchEvents()">
                            <i class="fas fa-search me-2"></i>Search
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Events -->
    <section class="py-5">
        <div class="container">
            <div class="row mb-4">
                <div class="col">
                    <h2 class="fw-bold">Featured Events</h2>
                    <p class="text-muted">Don't miss out on these upcoming university events</p>
                </div>
            </div>

            <% if (error) { %>
                <div class="alert alert-warning" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i><%= error %>
                </div>
            <% } %>

            <% if (events && events.length > 0) { %>
                <div class="row g-4" id="eventsGrid">
                    <% events.forEach(event => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="card event-card h-100">
                                <% if (event.images && event.images.length > 0) { %>
                                    <img src="<%= event.images[0].url %>" class="card-img-top event-image" alt="<%= event.name %>">
                                <% } else { %>
                                    <div class="card-img-top event-image-placeholder d-flex align-items-center justify-content-center bg-light">
                                        <i class="fas fa-calendar fa-3x text-muted"></i>
                                    </div>
                                <% } %>
                                
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title"><%= event.name %></h5>
                                    
                                    <% if (event.dates && event.dates.start) { %>
                                        <p class="card-text text-muted mb-2">
                                            <i class="fas fa-clock me-2"></i>
                                            <%= moment(event.dates.start.localDate).format('MMMM DD, YYYY') %>
                                            <% if (event.dates.start.localTime) { %>
                                                at <%= event.dates.start.localTime %>
                                            <% } %>
                                        </p>
                                    <% } %>
                                    
                                    <% if (event.venue) { %>
                                        <p class="card-text text-muted mb-2">
                                            <i class="fas fa-map-marker-alt me-2"></i>
                                            <%= event.venue.name %>
                                            <% if (event.venue.city) { %>
                                                , <%= event.venue.city %>
                                            <% } %>
                                        </p>
                                    <% } %>
                                    
                                    <p class="card-text flex-grow-1">
                                        <%= event.description ? event.description.substring(0, 100) + '...' : 'No description available' %>
                                    </p>
                                    
                                    <div class="mt-auto">
                                        <div class="btn-group w-100" role="group">
                                            <a href="/events/<%= event.id %>" class="btn btn-outline-primary">
                                                <i class="fas fa-info-circle me-1"></i>Details
                                            </a>
                                            <a href="<%= event.url %>" target="_blank" class="btn btn-outline-success">
                                                <i class="fas fa-ticket-alt me-1"></i>Get Tickets
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
                    <h3 class="text-muted">No Events Available</h3>
                    <p class="text-muted">Check back later for upcoming university events.</p>
                </div>
            <% } %>
        </div>
    </section>

    <!-- Features Section -->
    <section class="bg-light py-5">
        <div class="container">
            <div class="row text-center">
                <div class="col-md-4 mb-4">
                    <div class="feature-item">
                        <i class="fas fa-search fa-3x text-primary mb-3"></i>
                        <h4>Discover Events</h4>
                        <p>Browse through a wide variety of university events and activities</p>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="feature-item">
                        <i class="fas fa-user-check fa-3x text-success mb-3"></i>
                        <h4>Easy Registration</h4>
                        <p>Register for events with just a few clicks</p>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="feature-item">
                        <i class="fas fa-cloud-upload-alt fa-3x text-info mb-3"></i>
                        <h4>Upload Media</h4>
                        <p>Share event posters and images with the community</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Upload Modal -->
    <div class="modal fade" id="uploadModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Upload Event Poster</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="uploadForm" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="posterFile" class="form-label">Choose Poster Image</label>
                            <input type="file" class="form-control" id="posterFile" name="poster" accept="image/*" required>
                            <div class="form-text">Supported formats: JPEG, PNG, GIF, WebP (Max 5MB)</div>
                        </div>
                        <div class="mb-3">
                            <label for="eventName" class="form-label">Event Name</label>
                            <input type="text" class="form-control" id="eventName" placeholder="Enter event name">
                        </div>
                        <div class="mb-3">
                            <div id="uploadProgress" class="progress" style="display: none;">
                                <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="uploadPoster()">
                        <i class="fas fa-upload me-2"></i>Upload
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5>UniEvent</h5>
                    <p>University Event Management System powered by AWS</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0">
                        <small>&copy; 2024 UniEvent. Built for Cloud Computing Assignment</small>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="/js/main.js"></script>
</body>
</html>
